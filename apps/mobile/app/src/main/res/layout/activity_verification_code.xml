<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".activity.VerificationCodeActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/tb_verification_code"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:layout_marginTop="@dimen/space_24"
        android:background="@android:color/transparent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:titleCentered="false">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            tools:layout_editor_absoluteX="16dp"
            tools:ignore="UseCompoundDrawables">

            <ImageView
                android:id="@+id/logoIcon"
                android:layout_width="@dimen/icon_24"
                android:layout_height="@dimen/icon_24"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_logo_cibercheck" />

            <TextView
                android:id="@+id/tvAppName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_8"
                android:text="@string/app_name"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_16"
                android:textStyle="bold" />
        </LinearLayout>

    </com.google.android.material.appbar.MaterialToolbar>

    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_32"
        android:text="@string/title_verification"
        android:textColor="@color/black"
        android:textSize="@dimen/text_20"
        android:textStyle="bold"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tb_verification_code"

        android:layout_marginHorizontal="@dimen/space_24" />

    <TextView
        android:id="@+id/tvDescripcion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_8"
        android:text="@string/text_message_verification_email"
        android:textColor="@color/neutral_dark"
        android:textSize="@dimen/text_14"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitulo"

        android:layout_marginHorizontal="@dimen/space_24" />

    <TextView
        android:id="@+id/tvCorreo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_4"
        android:text="@string/txt_email"
        android:textColor="@color/state_ok"
        android:textSize="14sp"
        android:textStyle="bold"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDescripcion"

        android:layout_marginHorizontal="@dimen/space_24" />

    <LinearLayout
        android:id="@+id/layoutCodigo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_16"
        android:orientation="horizontal"
        android:gravity="center"
        android:contentDescription="@string/accessibility_code"

        app:layout_constraintTop_toBottomOf="@id/tvCorreo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/et1"
            style="@style/VerificationCodeInput"
            android:layout_width="@dimen/input_46"
            android:layout_height="@dimen/input_56"
            android:importantForAccessibility="yes"
            tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

        <EditText
            android:id="@+id/et2"
            style="@style/VerificationCodeInput"
            android:layout_width="@dimen/input_46"
            android:layout_height="@dimen/input_56"
            android:importantForAccessibility="yes"
            tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

        <EditText
            android:id="@+id/et3"
            style="@style/VerificationCodeInput"
            android:layout_width="@dimen/input_46"
            android:layout_height="@dimen/input_56"
            android:importantForAccessibility="yes"
            tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

        <EditText
            android:id="@+id/et4"
            style="@style/VerificationCodeInput"
            android:layout_width="@dimen/input_46"
            android:layout_height="@dimen/input_56"
            android:importantForAccessibility="yes"
            tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

        <EditText
            android:id="@+id/et5"
            style="@style/VerificationCodeInput"
            android:layout_width="@dimen/input_46"
            android:layout_height="@dimen/input_56"
            android:importantForAccessibility="yes"
            tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

        <EditText
            android:id="@+id/et6"
            style="@style/VerificationCodeInput"
            android:layout_width="@dimen/input_46"
            android:layout_height="@dimen/input_56"
            android:importantForAccessibility="yes"
            tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNoRecibi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/space_24"
        android:layout_marginTop="@dimen/space_16"
        android:text="@string/btn_not_code"
        android:textAllCaps="false"
        android:textColor="@color/text_btn"

        app:backgroundTint="@color/button_secondary"
        app:cornerRadius="@dimen/button_corner_25"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layoutCodigo" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVolver"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_return"
        android:textAllCaps="false"
        android:textColor="@color/white"

        app:backgroundTint="@color/button_primary"
        app:cornerRadius="@dimen/button_corner_25"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnNoRecibi"

        android:layout_marginHorizontal="@dimen/space_24" />

</androidx.constraintlayout.widget.ConstraintLayout>
